# AtoZ Jobs AI — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit the .env file — it is gitignored.

# === Supabase (Required) ===
# Get these from `supabase start` output (local) or Supabase dashboard (production)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# === Job API Keys (Required for collection) ===
REED_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=
CAREERJET_AFFID=

# === Embeddings (Required for pipeline) ===
GOOGLE_API_KEY=

# === AI Explanations (Required for web /api/explain) ===
OPENAI_API_KEY=

# === Company Enrichment (Optional — pipeline) ===
COMPANIES_HOUSE_API_KEY=

# === Modal Search (Required for web search via Modal) ===
MODAL_SEARCH_URL=

# === Monitoring (Optional — production only) ===
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
HELICONE_API_KEY=

# === Site Config (Optional — defaults provided) ===
NEXT_PUBLIC_SITE_URL=https://atozjobs.ai
NEXT_PUBLIC_POSTCODES_IO_URL=https://api.postcodes.io
