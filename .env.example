# ============================================================================
# AtoZ Jobs AI — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env files.
# ============================================================================

# --- Supabase (REQUIRED) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# --- Job APIs (REQUIRED for collectors — skip if missing) ---
REED_API_KEY=your-reed-api-key
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
JOOBLE_API_KEY=your-jooble-api-key
CAREERJET_AFFID=your-careerjet-affiliate-id

# --- Embeddings (REQUIRED for pipeline) ---
GOOGLE_API_KEY=your-google-genai-api-key
OPENAI_API_KEY=your-openai-api-key

# --- Enrichment (OPTIONAL — Companies House) ---
COMPANIES_HOUSE_API_KEY=your-companies-house-api-key

# --- Web: LLM Explanations (OPTIONAL — Phase 3) ---
# OPENAI_API_KEY is shared with embeddings fallback above
MODAL_SEARCH_URL=https://your-modal-app--search-endpoint.modal.run
HELICONE_API_KEY=your-helicone-api-key
LITELLM_API_KEY=your-litellm-api-key

# --- Web: Public Keys (OPTIONAL — production only) ---
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-project-key
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
NEXT_PUBLIC_SITE_URL=https://atozjobs.ai
NEXT_PUBLIC_POSTCODES_IO_URL=https://api.postcodes.io
SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0

# --- CI/CD (GitHub Actions secrets — not needed locally) ---
MODAL_TOKEN_ID=your-modal-token-id
MODAL_TOKEN_SECRET=your-modal-token-secret
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
